generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  INSTRUCTOR
  MEMBER
}

enum AuthProviderType {
  LOCAL
  GOOGLE
}

enum EnrollmentStatus {
  CONFIRMED
  CANCELLED
  WAITLIST
}

enum MembershipStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum EventStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String?
  isActive     Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roles         UserRoleAssignment[]
  authProviders AuthProvider[]

  memberships   Membership[]
  enrollments   EventEnrollment[]
  eventsCreated Event[]           @relation("EventsCreated")
  eventsTaught  Event[]           @relation("EventsTaught")
  payments      Payment[]

  refreshTokens RefreshToken[]

  @@index([email])
  @@index([isActive])
}

model UserRoleAssignment {
  id     String   @id @default(uuid()) @db.Uuid
  userId String   @db.Uuid
  role   UserRole

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
}

model AuthProvider {
  id         String            @id @default(uuid()) @db.Uuid
  userId     String            @db.Uuid
  provider   AuthProviderType
  providerId String?           // required for GOOGLE, null for LOCAL
  createdAt  DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@unique([userId, provider])
  @@index([userId])
}

model MembershipPlan {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique
  description  String?
  price        Decimal  @db.Decimal(10, 2)
  durationDays Int

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships Membership[]
}

model Membership {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  planId    String           @db.Uuid
  status    MembershipStatus

  startDate DateTime         @db.Date
  endDate   DateTime?        @db.Date

  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     MembershipPlan @relation(fields: [planId], references: [id])
  payments Payment[]

  @@index([userId])
  @@index([status])
}

model Payment {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @db.Uuid
  membershipId String?       @db.Uuid

  amount       Decimal       @db.Decimal(10, 2)
  status       PaymentStatus
  providerRef  String?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  membership Membership? @relation(fields: [membershipId], references: [id])

  @@index([userId])
  @@index([status])
}

model ClassType {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events Event[]
}

model Event {
  id           String      @id @default(uuid()) @db.Uuid
  title        String

  instructorId String      @db.Uuid
  classTypeId  String      @db.Uuid
  createdBy    String      @db.Uuid

  startTime    DateTime
  endTime      DateTime
  capacity     Int
  status       EventStatus

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  instructor  User      @relation("EventsTaught", fields: [instructorId], references: [id])
  creator     User      @relation("EventsCreated", fields: [createdBy], references: [id])
  classType   ClassType @relation(fields: [classTypeId], references: [id])
  enrollments EventEnrollment[]

  @@index([startTime])
  @@index([status])
  @@index([instructorId])
  @@index([classTypeId])
}

model EventEnrollment {
  id        String           @id @default(uuid()) @db.Uuid
  eventId   String           @db.Uuid
  userId    String           @db.Uuid
  status    EnrollmentStatus

  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model RefreshToken {
id String @id @default(uuid()) @db.Uuid
userId String @db.Uuid
tokenHash String
expiresAt DateTime
revoked Boolean @default(false)

createdAt DateTime @default(now())

user User @relation(fields: [userId], references: [id], onDelete: Cascade)

@@index([userId])
@@index([expiresAt])
}